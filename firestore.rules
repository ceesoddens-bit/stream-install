rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Helpers ===
    function isSignedIn() { return request.auth != null; }
    function tenantId() { return request.auth.token.tenantId; }
    function sameTenant(t) { return isSignedIn() && tenantId() == t; }
    function role() { return request.auth.token.role; }
    function isOwner() { return isSignedIn() && role() == 'owner'; }
    function isOwnerOrAdmin() { return isSignedIn() && role() in ['owner', 'admin']; }
    function isMember() { return isSignedIn() && role() == 'member'; }
    function isAnyMember() { return isSignedIn() && role() in ['owner', 'admin', 'member']; }
    function isCustomer() { return isSignedIn() && role() == 'customer'; }

    function tenantData(tId) {
      return get(/databases/$(database)/documents/tenants/$(tId)).data;
    }

    function hasModule(tId, moduleKey) {
      let inbegrepen = moduleKey in ['crm', 'dashboarding'];
      return inbegrepen || moduleKey in tenantData(tId).actiefModules;
    }

    function isOwnContact(contactId) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.contactId == contactId;
    }

    // === Tenants ===
    match /tenants/{tId} {
      allow read: if sameTenant(tId);
      allow update: if sameTenant(tId) && isOwnerOrAdmin();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if false;

      // ----- CRM -----
      match /companies/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow create, update, delete: if sameTenant(tId) && isOwnerOrAdmin();
      }

      match /contacts/{docId} {
        allow read: if sameTenant(tId) && (
          isAnyMember() ||
          (isCustomer() && isOwnContact(docId))
        );
        allow create, update: if sameTenant(tId) && isAnyMember();
        allow delete: if sameTenant(tId) && isOwnerOrAdmin();
      }

      match /tags/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin();
      }

      // ----- Projects -----
      match /projects/{docId} {
        allow read: if sameTenant(tId) && (isAnyMember() || isCustomer());
        allow create, update: if sameTenant(tId) && isAnyMember() && hasModule(tId, 'projectmanagement');
        allow delete: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'projectmanagement');
      }

      match /project_groups/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin();
      }

      // ----- Finance -----
      match /quotes/{docId} {
        allow read: if sameTenant(tId) && (
          isAnyMember() ||
          (isCustomer() && resource.data.contactId != null && isOwnContact(resource.data.contactId))
        );
        allow create: if sameTenant(tId) && isAnyMember() && hasModule(tId, 'offertes');
        allow update: if sameTenant(tId) && (
          (isAnyMember() && hasModule(tId, 'offertes')) ||
          (isCustomer() && resource.data.status == 'Verstuurd' && request.resource.data.status == 'Geaccepteerd')
        );
        allow delete: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'offertes');
      }

      match /invoices/{docId} {
        allow read: if sameTenant(tId) && (
          isAnyMember() ||
          (isCustomer() && resource.data.contactId != null && isOwnContact(resource.data.contactId))
        );
        allow create, update, delete: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'facturering');
      }

      match /purchase_invoices/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'facturering');
      }

      match /payments/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'facturering');
      }

      match /counters/{docId} {
        allow read, write: if sameTenant(tId) && isOwnerOrAdmin();
      }

      // ----- Tickets -----
      match /tickets/{docId} {
        allow read: if sameTenant(tId) && (
          isAnyMember() ||
          (isCustomer() && resource.data.contactId != null && isOwnContact(resource.data.contactId))
        );
        allow create: if sameTenant(tId)
          && (isAnyMember() || isCustomer())
          && hasModule(tId, 'projectmanagement');
        allow update, delete: if sameTenant(tId)
          && isAnyMember()
          && hasModule(tId, 'projectmanagement');

        match /comments/{commentId} {
          allow read: if sameTenant(tId);
          allow create: if sameTenant(tId);
          allow update, delete: if sameTenant(tId) && request.auth.uid == resource.data.authorId;
        }
      }

      // ----- Hours / Tasks -----
      match /hours/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow create, update: if sameTenant(tId) && isAnyMember() && hasModule(tId, 'projectmanagement');
        allow delete: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'projectmanagement');
      }

      match /tasks/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isAnyMember() && hasModule(tId, 'projectmanagement');
      }

      // ----- Planning -----
      match /planning/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isAnyMember() && hasModule(tId, 'planning');
      }

      match /planning_cards/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'planning');
      }

      match /teams/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'planning');
      }

      match /technicians/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'planning');
      }

      // ----- Inventory -----
      match /inventory/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isAnyMember() && hasModule(tId, 'voorraadbeheer');
      }
      match /suppliers/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'voorraadbeheer');
      }
      match /warehouses/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'voorraadbeheer');
      }
      match /bom_items/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'voorraadbeheer');
      }
      match /purchase_orders/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'voorraadbeheer');
      }
      match /mutations/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isAnyMember() && hasModule(tId, 'voorraadbeheer');
      }
      match /stock_overview/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if false;
      }

      // ----- Forms -----
      match /form_templates/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'formulieren');
      }
      match /form_items/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow create, update: if sameTenant(tId) && isAnyMember() && hasModule(tId, 'formulieren');
        allow delete: if sameTenant(tId) && isOwnerOrAdmin() && hasModule(tId, 'formulieren');
      }

      // ----- Settings / Invites -----
      match /settings/global_timer {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isAnyMember();
      }
      match /settings/{docId} {
        allow read: if sameTenant(tId) && isAnyMember();
        allow write: if sameTenant(tId) && isOwnerOrAdmin();
      }
      match /invites/{token} {
        allow read: if true; // token zelf is het geheim
        allow create, delete: if sameTenant(tId) && isOwner();
        allow update: if (sameTenant(tId) && isOwner())
          || (isSignedIn() && request.resource.data.status == 'accepted'
              && request.resource.data.usedByUid == request.auth.uid);
      }
    }

    // === Users ===
    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid ||
        (sameTenant(resource.data.tenantId) && isOwnerOrAdmin())
      );
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.tenantId is string
        && request.resource.data.role is string;
      allow update: if request.auth.uid == uid ||
        (isSignedIn() && sameTenant(resource.data.tenantId) && isOwnerOrAdmin());
      allow delete: if false;
    }

    // === Mail (Trigger Email Extension) ===
    match /mail/{id} {
      allow read, write: if false; // alleen via Admin SDK
    }

    // === Stripe Payments Extension ===
    match /customers/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      match /checkout_sessions/{id} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
      match /{document=**} {
        allow read: if isSignedIn() && request.auth.uid == uid;
      }
    }
    match /products/{id} {
      allow read: if true;
      match /prices/{priceId} { allow read: if true; }
      match /tax_rates/{taxId} { allow read: if true; }
    }
  }
}
